      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Bonitaet_Join_di" bpmnElement="Flow_Bonitaet_Join">
        <di:waypoint x="720" y="140" />
        <di:waypoint x="810" y="140" />
        <di:waypoint x="810" y="215" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Dokumente_Join_di" bpmnElement="Flow_Dokumente_Join">
        <di:waypoint x="720" y="340" />
        <di:waypoint x="810" y="340" />
