          <dc:Bounds x="245" y="272" width="71" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1072" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1056" y="265" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sub_Bonitaet_di" bpmnElement="Sub_Bonitaet" isExpanded="true">
        <dc:Bounds x="370" y="80" width="350" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_Bonitaet_di" bpmnElement="Start_Bonitaet">
        <dc:Bounds x="400" y="122" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Bonitaet_di" bpmnElement="Task_Bonitaet">
        <dc:Bounds x="490" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Bonitaet_di" bpmnElement="End_Bonitaet">
        <dc:Bounds x="642" y="122" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_b1_di" bpmnElement="Flow_b1">
        <di:waypoint x="436" y="140" />
        <di:waypoint x="490" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_b2_di" bpmnElement="Flow_b2">
        <di:waypoint x="590" y="140" />
        <di:waypoint x="642" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Sub_Dokumente_di" bpmnElement="Sub_Dokumente" isExpanded="true">
        <dc:Bounds x="370" y="280" width="350" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_Dokumente_di" bpmnElement="Start_Dokumente">
        <dc:Bounds x="400" y="322" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Dokumente_di" bpmnElement="Task_Dokumente">
        <dc:Bounds x="490" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Dokumente_di" bpmnElement="End_Dokumente">
        <dc:Bounds x="642" y="322" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_d1_di" bpmnElement="Flow_d1">
        <di:waypoint x="436" y="340" />
        <di:waypoint x="490" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_d2_di" bpmnElement="Flow_d2">
        <di:waypoint x="590" y="340" />
        <di:waypoint x="642" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Gateway_Join_di" bpmnElement="Gateway_Join">
        <dc:Bounds x="785" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="701" y="226" width="74" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_Fork_di" bpmnElement="Flow_Start_Fork">
        <di:waypoint x="196" y="240" />
        <di:waypoint x="255" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Fork_Bonitaet_di" bpmnElement="Flow_Fork_Bonitaet">
        <di:waypoint x="280" y="215" />
        <di:waypoint x="280" y="140" />
        <di:waypoint x="370" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Fork_Dokumente_di" bpmnElement="Flow_Fork_Dokumente">
        <di:waypoint x="280" y="265" />
