<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Urlaubsantrag" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <bpmn:process id="urlaubsantrag" name="Urlaubsantrag" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:startEvent id="StartEvent_1" name="Urlaubsantrag&#10;gestellt" camunda:formRef="urlaubsantragStart" camunda:formRefBinding="deployment">
      <bpmn:outgoing>Flow_start_gateway</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_start_gateway" sourceRef="StartEvent_1" targetRef="Gateway_pruefung" />
    <bpmn:exclusiveGateway id="Gateway_pruefung" name="Mehr als 5&#10;Urlaubstage?" default="Flow_auto_genehmigt">
      <bpmn:incoming>Flow_start_gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_auto_genehmigt</bpmn:outgoing>
      <bpmn:outgoing>Flow_zur_genehmigung</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_auto_genehmigt" name="≤ 5 Tage&#10;(automatisch genehmigt)" sourceRef="Gateway_pruefung" targetRef="EndEvent_1" />
    <bpmn:sequenceFlow id="Flow_zur_genehmigung" name="&#62; 5 Tage" sourceRef="Gateway_pruefung" targetRef="Task_genehmigung">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${urlaubstage &gt; 5}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="Task_genehmigung" name="Antrag genehmigen" camunda:formRef="urlaubsantragGenehmigung" camunda:formRefBinding="deployment" camunda:assignee="demo">
      <bpmn:incoming>Flow_zur_genehmigung</bpmn:incoming>
      <bpmn:outgoing>Flow_genehmigung_ende</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_genehmigung_ende" sourceRef="Task_genehmigung" targetRef="EndEvent_1" />
    <bpmn:endEvent id="EndEvent_1" name="Antrag&#10;abgeschlossen">
      <bpmn:incoming>Flow_auto_genehmigt</bpmn:incoming>
      <bpmn:incoming>Flow_genehmigung_ende</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="urlaubsantrag">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="182" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="170" y="185" width="62" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_pruefung_di" bpmnElement="Gateway_pruefung" isMarkerVisible="true">
        <dc:Bounds x="295" y="135" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="287" y="95" width="66" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_genehmigung_di" bpmnElement="Task_genehmigung">
        <dc:Bounds x="420" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="692" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="680" y="185" width="62" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_start_gateway_di" bpmnElement="Flow_start_gateway">
        <di:waypoint x="218" y="160" />
        <di:waypoint x="295" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_auto_genehmigt_di" bpmnElement="Flow_auto_genehmigt">
        <di:waypoint x="345" y="160" />
        <di:waypoint x="692" y="160" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="455" y="126" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_zur_genehmigung_di" bpmnElement="Flow_zur_genehmigung">
        <di:waypoint x="320" y="185" />
        <di:waypoint x="320" y="320" />
        <di:waypoint x="420" y="320" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="333" y="293" width="44" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_genehmigung_ende_di" bpmnElement="Flow_genehmigung_ende">
        <di:waypoint x="520" y="320" />
        <di:waypoint x="710" y="320" />
        <di:waypoint x="710" y="178" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
